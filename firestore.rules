rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: voice_analyses
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required) - The UID of the user
    //   - originalText: string (optional)
    //   - correctedText: string (required)
    //   - vocalProfile: map (optional)
    //   - audioUrl: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - role: string (required) - 'admin' or 'user'
    //   - email: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "karthikeya39g@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidVoiceAnalysis(data) {
      return data.keys().hasAll(['userId', 'correctedText', 'createdAt']) &&
             data.userId is string &&
             data.correctedText is string &&
             data.correctedText.size() < 10000 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /voice_analyses/{analysisId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && 
                      isValidVoiceAnalysis(request.resource.data) && 
                      request.resource.data.userId == request.auth.uid;
      allow update, delete: if isDocOwner() || isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && request.resource.data.role == 'user';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
